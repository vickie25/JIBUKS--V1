{
  "info": {
    "name": "JIBUKS Admin APIs",
    "description": "Postman collection for JIBUKS Platform Administration",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:4001/api",
      "type": "string"
    },
    {
      "key": "admin_token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Admin Auth",
      "item": [
        {
          "name": "Login Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.accessToken) {",
                  "    pm.collectionVariables.set('admin_token', jsonData.accessToken);",
                  "    console.log('Token successfully captured');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"apbcafricait@gmail.com\",\n  \"password\": \"admin123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/admin/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "admin",
                "login"
              ]
            }
          }
        },
        {
          "name": "Get Current Admin (Me)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/admin/me",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "admin",
                "me"
              ]
            }
          }
        },
        {
          "name": "Logout Admin",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/admin/logout",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "admin",
                "logout"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Tenant Management",
      "item": [
        {
          "name": "Get Platform Stats",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/admin/management/tenants/stats",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "admin",
                "management",
                "tenants",
                "stats"
              ]
            }
          }
        },
        {
          "name": "Get All Tenants (Extensive)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/admin/management/tenants",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "admin",
                "management",
                "tenants"
              ]
            }
          }
        },
        {
          "name": "Get Tenant By ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/admin/management/tenants/1",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "admin",
                "management",
                "tenants",
                "1"
              ]
            }
          }
        },
        {
          "name": "Update Tenant",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Tenant Name\",\n  \"slug\": \"updated-tenant\",\n  \"tenantType\": \"BUSINESS\",\n  \"ownerEmail\": \"newowner@example.com\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/admin/management/tenants/1",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "admin",
                "management",
                "tenants",
                "1"
              ]
            }
          }
        },
        {
          "name": "Delete Tenant",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/admin/management/tenants/1",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "admin",
                "management",
                "tenants",
                "1"
              ]
            }
          }
        }
      ]
    }
  ]
}
